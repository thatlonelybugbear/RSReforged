{
	"id": "rsreforged",
	"title": "RSReforged",
	"description": "Quality-of-life roll automation for the dnd5e system. A maintained fork of Ready Set Roll for D&D5e by MangoFVTT (itself a rewrite of Better Rolls for 5e by RedReign). Targets Foundry VTT v14+ and dnd5e 5.3+.",
	"version": "4.7.2",
	"compatibility": {
		"minimum": "14",
		"verified": "14.539",
		"maximum": "14"
	},
	"authors": [
		{
			"name": "arrowedisgaming",
			"url": "https://github.com/arrowedisgaming"
		},
		{
			"name": "MangoFVTT",
			"discord": "MangoFVTT",
			"flags": { "role": "Original Ready Set Roll author" }
		},
		{
			"name": "RedReign",
			"flags": { "role": "Better Rolls 5e (ancestor project)" }
		}
	],
	"esmodules": [
		"./src/rsreforged.js",
		"./src/module/config.js"
	],
	"styles": [
		"./css/rsreforged.css"
	],
	"languages": [
		{
			"lang": "en",
			"name": "English",
			"path": "lang/en.json"
		},
		{
			"lang": "pt-BR",
